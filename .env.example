# ============================================================
# BITÁCORA DEL TIEMPO — Variables de Entorno
# Copia este archivo como .env y completa los valores
# NUNCA subas .env a GitHub (ya está en .gitignore)
# ============================================================

# ── GEMINI AI ────────────────────────────────────────────────
# Obtener en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy...tu_clave_aqui

# ── HUGGING FACE (para imágenes SDXL fallback) ───────────────
# Obtener en: https://huggingface.co/settings/tokens
# Crear token tipo "read"
HF_TOKEN=hf_...tu_token_aqui

# ── YOUTUBE API ──────────────────────────────────────────────
# Paso 1: https://console.cloud.google.com → Nuevo proyecto
# Paso 2: APIs & Services → Enable "YouTube Data API v3"
# Paso 3: Credentials → Create OAuth 2.0 Client ID → Desktop app
# Paso 4: python youtube_uploader.py → copia el REFRESH_TOKEN
YT_CLIENT_ID=123456789-abcdef.apps.googleusercontent.com
YT_CLIENT_SECRET=GOCSPX-...tu_secret_aqui
YT_REFRESH_TOKEN=1//0...tu_refresh_token_aqui

# ── TTS (Text-to-Speech) ─────────────────────────────────────
TTS_VOICE=es-MX-JorgeNeural
TTS_RATE=+10%
TTS_VOLUME=+0%

# ── SERVER ───────────────────────────────────────────────────
PORT=8080
OUTPUT_DIR=/tmp/bitacora

# ── RENDER (solo para Make.com y scripts locales) ────────────
# Tu URL de Render después de hacer deploy
RENDER_URL=https://bitacora-del-tiempo.onrender.com

# ── FACEBOOK (opcional) ──────────────────────────────────────
# https://developers.facebook.com → Graph API → Page Access Token
FB_PAGE_TOKEN=
FB_PAGE_ID=
